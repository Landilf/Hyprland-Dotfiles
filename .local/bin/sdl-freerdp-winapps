#!/run/current-system/sw/bin/bash
set -euo pipefail

# Workaround for Hyprland/Wayland + (sometimes) OpenGL renderer issues in FreeRDP SDL client.
# Force software renderer to avoid freezes when RemoteApps create/resize windows.
export SDL_RENDER_DRIVER="${SDL_RENDER_DRIVER:-software}"

want_debug=0
for a in "$@"; do
  if [[ "$a" == /app:*FreeRDP_Connection_Test* ]]; then
    want_debug=1
    break
  fi
done

args=()
if [[ $want_debug -eq 1 ]]; then
  # Make WinApps setup failures diagnosable (connection fails early, so logs stay small).
  args+=(
    /log-level:TRACE
    /log-filters:com.freerdp.core.transport:TRACE,com.freerdp.core.nego:TRACE,com.freerdp.core.nla:TRACE,com.freerdp.core.rdp:DEBUG,com.winpr.sspi:TRACE
  )
fi

for arg in "$@"; do
  # WinApps setup verifies RDP+drive redirection by running a RemoteApp cmd.exe
  # that immediately writes a file into \\tsclient\home\... and then tsdiscon's.
  # On some systems the redirected drive isn't ready instantly, so add a small
  # delay before the write to avoid false failures.
  if [[ "$arg" == /app:*FreeRDP_Connection_Test*tsdiscon* ]]; then
    original_arg="$arg"
    # Keep cmd.exe (RemoteApp policies may block PowerShell), but add a delay
    # before the write. `ping` is available on all Windows versions.
    # NOTE: In bash parameter substitution, '&' expands to the matched text.
    # Use '\&' (literal backslash + ampersand) to insert a literal '&'.
    arg="${arg//cmd:\"\/C type NUL > /cmd:\"\/C ping -n 6 127.0.0.1 >NUL \& type NUL > }"
    arg="${arg//cmd:\/C type NUL > /cmd:\/C ping -n 6 127.0.0.1 >NUL \& type NUL > }"
    printf '[winapps-freerdp-wrapper] patched RemoteApp test cmd:\n  from: %s\n  to:   %s\n' "$original_arg" "$arg" >&2
  fi
  args+=("$arg")
done

exec /nix/store/b2y8zw4q97xb92g6lsk7w3q5q6dn3fjp-freerdp-3.23.0/bin/sdl-freerdp "${args[@]}"
